# First address of anvil
export SOURCE_DEPLOYER_PRIVATE_KEY=0xcc7d9e07af6e7afee60324f7f008d6fe19b815f495ed97068b8185a2cb9ad0dc
export SOURCE_DEPLOYER_ADDRESS=0x71a635Fe3EaCfEc8d2CdFa376D7099dF46290012

# First address of anvil
export DESTINATION_DEPLOYER_PRIVATE_KEY=0xd87e862857d2797cb1da51dfbf4ca2a2e2c6716d2165feb4043455739c33a592
export DESTINATION_DEPLOYER_ADDRESS=0x1eE9b6a233323A590035FcEbBb1712c9D7373179

# Second address of Anvil
export SOURCE_CHAIN_RELAYER_ADDRESS=0xBCDc056737eEBd745C99A8116c01Ed705C4aE51B
export DESTINATION_CHAIN_RELAYER_ADDRESS=0x76926382d9Bfe61cEa0Bb16E20857526D82e004D

export SOURCE_HYP_KEY=$SOURCE_DEPLOYER_PRIVATE_KEY
export SOURCE_HYP_ADDRESS=`cast wallet address --private-key=$SOURCE_HYP_KEY`

export DESTINATION_HYP_KEY=$DESTINATION_DEPLOYER_PRIVATE_KEY
export DESTINATION_HYP_ADDRESS=`cast wallet address --private-key=$DESTINATION_HYP_KEY`

# CAFF node dev priv key
export CAFF_NODE_DEV_PRIV_KEY=0xb6b15c8cb491557369f3c7d2c287b053eb229daa9c22138887752191c9520659

# RPC config for Caff node
export RPC_SOURCE_CHAIN_PORT=8547
export SOURCE_CHAIN_RPC_URL=http://localhost:$RPC_SOURCE_CHAIN_PORT

# RPC config for Anvil node
export RPC_DESTINATION_CHAIN_PORT=8549
export DESTINATION_CHAIN_RPC_URL=http://localhost:$RPC_DESTINATION_CHAIN_PORT


export ESPRESSO_APP_CONTRACTS_DATA_FILE_SOURCE=/tmp/source_espresso_app_deploy.json
export ESPRESSO_APP_CONTRACTS_DATA_FILE_DESTINATION=/tmp/destination_espresso_app_deploy.json
export CHAIN_NAME=source



# Source chain id corresponding to the caff node
export SOURCE_CHAIN_ID=412346
export SOURCE_CHAIN_SEED=$SOURCE_CHAIN_ID

# Destination chain id corresponding to the anvil node
export DESTINATION_CHAIN_ID=31338
export DESTINATION_CHAIN_SEED=$DESTINATION_CHAIN_ID
